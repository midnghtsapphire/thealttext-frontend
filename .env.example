# ══════════════════════════════════════════════════════════════════════════════
# TheAltText Frontend — Environment Configuration
# A GlowStarLabs product by Audrey Evans
# https://meetaudreyevans.com
# ══════════════════════════════════════════════════════════════════════════════

# ── API Backend URL ──────────────────────────────────────────────────────────
# The URL of the TheAltText Backend API server.
# In development, this is typically http://localhost:8000
# In production, set to your deployed backend URL (e.g., https://api.thealttext.com)
VITE_API_URL=http://localhost:8000/api

# ── Stripe Billing Mode ─────────────────────────────────────────────────────
# Toggle between test and live Stripe environments.
# Values: test | live
VITE_STRIPE_MODE=test

# ── Stripe Test Mode Keys ───────────────────────────────────────────────────
VITE_STRIPE_TEST_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# ── Stripe Live Mode Keys ───────────────────────────────────────────────────
VITE_STRIPE_LIVE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx

# ── Feature Flags ────────────────────────────────────────────────────────────
# Enable demo mode (uses mock API, no backend required)
VITE_DEMO_MODE=true

# Enable e-commerce product listing mode
VITE_ECOMMERCE_MODE=true

# Enable AI-suggested image improvements
VITE_AI_SUGGESTIONS=true

# Enable WCAG compliance score display
VITE_WCAG_SCORE_DISPLAY=true

# Enable before/after accessibility preview
VITE_BEFORE_AFTER_PREVIEW=true

# ── OpenRouter (client-side demo fallback) ───────────────────────────────────
# Only used in demo mode for client-side AI calls
VITE_OPENROUTER_API_KEY=

# ── Branding ─────────────────────────────────────────────────────────────────
VITE_BRAND_NAME=GlowStarLabs
VITE_BRAND_URL=https://meetaudreyevans.com
VITE_BRAND_AUTHOR=Audrey Evans
